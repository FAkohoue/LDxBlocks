assoc_qk <- test_block_haplotypes(
  haplotypes = haps,
  blues      = setNames(ldx_blues$YLD, ldx_blues$id),
  blocks     = ldx_blocks,
  n_pcs      = 3L,
  verbose    = FALSE
)


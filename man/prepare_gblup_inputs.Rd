library(sommer)
fit  <- sommer::mmes(trait ~ 1, random = ~vsm(ism(id), Gu = inp$G),
             data = inp$pheno_df)
gebv <- fit$U$`u:id`$trait

# BGLR
library(BGLR)
fit  <- BGLR(y = inp$y_vec, ETA = list(list(K = inp$G, model = "RKHS")))
gebv <- fit$yHat
}

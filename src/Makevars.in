## src/Makevars.in
##
## Generated by configure into src/Makevars
##
## @OPENMP_CXXFLAGS@ and @OPENMP_LIBS@ are substituted by configure.
## On macOS they are intentionally left empty so the package builds
## single-threaded and avoids libomp runtime loading issues.

PKG_CXXFLAGS = @OPENMP_CXXFLAGS@ -DARMA_NO_DEBUG
PKG_LIBS     = @OPENMP_LIBS@ $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)

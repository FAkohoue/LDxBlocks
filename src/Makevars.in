## src/Makevars  (generated from src/Makevars.in by configure)
##
## Do not edit this file directly — edit src/Makevars.in and re-run configure.
##
## OPENMP_CXXFLAGS and OPENMP_LIBS are set by the configure script:
##   - Linux/other: -fopenmp / -fopenmp (GCC links libgomp automatically)
##   - macOS:       -Xpreprocessor -fopenmp -I<libomp>/include
##                  / -L<libomp>/lib -lomp -Wl,-rpath,<libomp>/lib
##   - No OpenMP:   empty (build falls back to single-threaded)
##
## ARMA_NO_DEBUG: disables Armadillo tinyformat warnings from binutils>=2.40.
PKG_CXXFLAGS = @OPENMP_CXXFLAGS@ -DARMA_NO_DEBUG
PKG_LIBS     = @OPENMP_LIBS@ $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)

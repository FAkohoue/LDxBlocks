## src/Makevars.in
##
## Generated by configure into src/Makevars
##
## -fopenmp and -fopenmp are substituted by configure.
## On macOS they are intentionally left empty so the package builds
## single-threaded and avoids libomp runtime loading issues.

PKG_CXXFLAGS = -fopenmp -DARMA_NO_DEBUG
PKG_LIBS     = -fopenmp $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)

Package: LDxBlocks
Type: Package
Title: Genome-Wide LD Block Detection, Haplotype Analysis, and Genomic Prediction (r^2 and rV^2, C++ Accelerated)
Version: 0.3.1
Date: 2025-04-07
Authors@R:
    person(
      given   = "Félicien",
      family  = "Akohoue",
      email   = "akohoue.f@gmail.com",
      role    = c("aut", "cre"),
      comment = c(ORCID = "0000-0002-2160-0182")
